<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 네트워크 연결 사용 -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- 네트워크 연결 상태 체크 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" /> <!-- 🔔 알림 권한 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_teumteumeat"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_teumteumeat_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeumTeumEat"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        tools:targetApi="31">

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/app_ad_id"/>

        <activity
            android:name=".ui.screen.a4_main.a4_6_guide_expired_goal.GuideExpiredGoalActivity"
            android:exported="true"
            android:label="@string/title_activity_guide_expired_goal"
            android:theme="@style/Theme.TeumTeumEat" />

        <service
            android:name=".utils.firebase.TeumFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <!--
 Set custom default icon. This is used when no icon is set for incoming notification messages.
     See README(https://goo.gl/l4GJaQ) for more.
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher_teumteumeat_round" />
        <!--
 Set color used with incoming notification messages. This is used when no color is set for the incoming
             notification message. See README(https://goo.gl/6BKBk7) for more.
        -->
        <activity
            android:name=".ui.screen.a4_main.a4_5_add_goal.AddGoalActivity"
            android:exported="true"
            android:label="@string/title_activity_add_category_goal"
            android:theme="@style/Theme.TeumTeumEat"
            android:windowSoftInputMode="adjustResize" /> <!-- 카카오 앱 키 -->
        <meta-data
            android:name="com.kakao.sdk.AppKey"
            android:value="@string/kakao_native_app_key_scheme" /> <!-- 스플래쉬 화면 -->
        <activity
            android:name=".ui.screen.a0_splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- a1 - 로그인 화면 -->
        <activity
            android:name=".ui.screen.a1_login.LoginActivity"
            android:exported="true" />
        <activity
            android:name="com.kakao.sdk.auth.AuthCodeHandlerActivity"
            android:exported="true">

            <!-- 카카오 웹뷰 딥링크 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="oauth"
                    android:scheme="kakao2d5b8758966c24367eebd1926dd090bf" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.screen.a1_login.webView.KakaoLoginWebViewActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity
            android:name=".ui.screen.a2_on_boarding.OnBoardingActivity"
            android:exported="true"
            android:label="@string/title_activity_on_boarding"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.screen.unused_welcome.WelcomeActivity"
            android:exported="true" />
        <activity
            android:name=".ui.screen.a4_main.MainActivity"
            android:exported="true"
            android:label="@string/title_activity_home"></activity> <!-- b-1 퀴즈플로우 - 요약 화면 -->
        <activity
            android:name=".ui.screen.b1_summary.SummaryActivity"
            android:exported="true"
            android:label="@string/title_activity_summary"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.b2_quiz.QuizActivity"
            android:exported="true"
            android:label="@string/title_activity_quiz"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.b3_quiz_result.QuizResultActivity"
            android:exported="true"
            android:label="@string/title_activity_quiz_finish"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.c1_mypage.MyPageActivity"
            android:exported="true"
            android:label="MyPageActivity"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.c2_goal_list.GoalListActivity"
            android:exported="true"
            android:label="GoalDetailActivity"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.c3_edit_user_info.EditUserInfoActivity"
            android:exported="true"
            android:label="EditUserInfoActivity"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.a4_main.a4_3_daily_summary_detail.DailySummaryActivity"
            android:exported="true"
            android:label="DailySummaryDetailActivity"
            android:theme="@style/Theme.TeumTeumEat" />
        <activity
            android:name=".ui.screen.a4_main.a4_4_daily_quiz_result.DailyQuizResultActivity"
            android:exported="true"
            android:label="DailySummaryDetailActivity"
            android:theme="@style/Theme.TeumTeumEat" />
    </application>

</manifest>